{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ai-dememory hook-event dispatch --client codex --event UserPromptSubmit",
            "commandWindows": "ai-dememory hook-event dispatch --client codex --event UserPromptSubmit",
            "timeout": 15,
            "statusMessage": "Recalling relevant project memory"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "ai-dememory hook-event dispatch --client codex --event PreCompact",
            "commandWindows": "ai-dememory hook-event dispatch --client codex --event PreCompact",
            "timeout": 15,
            "statusMessage": "Capturing pre-compact memory metadata"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "ai-dememory hook-event dispatch --client codex --event PostCompact",
            "commandWindows": "ai-dememory hook-event dispatch --client codex --event PostCompact",
            "timeout": 15,
            "statusMessage": "Capturing post-compact memory metadata"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ai-dememory hook-event dispatch --client codex --event Stop",
            "commandWindows": "ai-dememory hook-event dispatch --client codex --event Stop",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
